    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/infrastructure/seeders/seeder.ts"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@neondatabase/serverless": "^1.0.2",
    "@nestjs/cache-manager": "^3.0.1",
