    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "bcryptjs": "^3.0.3",
    "cacheable": "^2.3.2",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "file-stream-rotator": "^1.0.0",
    "keyv": "^5.6.0",
    "mailtrap": "^4.5.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nestjs-pino": "^4.5.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^10.5.0",
