{
  "name": "@debridgers/debridgers-backend",
  "version": "1.0.0",
  "description": "Debridgers backend API — NestJS + Drizzle",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest --run",
    "db:generate": "drizzle-kit generate",
