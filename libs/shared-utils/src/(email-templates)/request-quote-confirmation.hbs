
<html>
  <head>
    <meta charset="utf-8" />
    <title>Quote Request Received</title>
  </head>
  <body
    style="margin:0; padding:0; font-family: Arial, sans-serif; background:#f4f4f4;"
  >
    <div
      style="max-width:600px; margin:40px auto; background:white; border-radius:12px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.1);"
    >
      <div style="background:#2B6036; padding:40px 20px; text-align:center;">
        <h1 style="color:white; margin:0; font-size:32px;">Thank You,
          {{contactPerson}}!</h1>
      </div>
      <div style="padding:40px 32px; text-align:center;">
        <p style="font-size:18px; color:#333;">Your quote request has been
          received</p>
        <p style="font-size:16px; color:#555; line-height:1.7;">
          We’ve received your request for
          <strong>{{quantity}} tons</strong>
          of
          <strong>{{product}}</strong>
          to
          <strong>{{destinationPort}}</strong>.
        </p>
        <div
          style="background:#f0f8f0; padding:24px; border-radius:8px; margin:32px auto; max-width:460px; border-left:5px solid #2B6036;"
        >
          <p style="margin:0; color:#1e4d2b;">
            Our export manager will contact you within
            <strong>24 hours</strong>
            with pricing and availability.
          </p>
        </div>
        <p style="color:#666; font-size:15px;">
          Questions? Reply to this email or call
          <a href="tel:+2347012288798">07012288798</a>
        </p>
      </div>
      <div
        style="background:#f0f0f0; padding:24px; text-align:center; font-size:12px; color:#999;"
      >
        ©
        {{year}}
        Debridger • Quote Request ID:
        {{year}}-{{random}}
      </div>
    </div>
  </body>
</html>