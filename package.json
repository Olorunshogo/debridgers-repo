{
  "name": "debridgers-repo",
  "version": "1.0.0",
  "description": "A marketplace platform connecting farmers directly with buyers for fresh farm produce.",
  "private": true,
  "main": "index.js",
  "keywords": [
    "farm",
    "produce",
    "marketplace",
    "farmers",
    "buyers",
    "fresh-produce",
    "agriculture",
    "farm-to-table",
    "ecommerce",
    "monorepo"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prepare": "husky || true",
    "dev:landing": "pnpm --filter @debridgers/landing-page dev",
    "build:landing": "pnpm --filter @debridgers/landing-page build",
    "typecheck:landing": "pnpm --filter @debridgers/landing-page typecheck",
    "dev:backend": "pnpm --filter @debridgers/debridgers-backend dev",
    "build:backend": "pnpm --filter @debridgers/debridgers-backend build",
    "db:migrate": "pnpm --filter @debridgers/debridgers-backend db:migrate",
    "db:generate": "pnpm --filter @debridgers/debridgers-backend db:generate",
    "db:seed": "pnpm --filter @debridgers/debridgers-backend db:seed",
    "test:e2e": "pnpm --filter @debridgers/debridgers-backend-e2e test",
    "dev:ui-web": "pnpm --filter @debridgers/ui-web dev",
    "build:ui-web": "pnpm --filter @debridgers/ui-web build",
    "watch:ui-web": "pnpm --filter @debridgers/ui-web watch"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tsup": "^8.0.1",
    "typescript": "^5.9.2",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "validate-branch-name": {
    "pattern": "^(main|develop|live){1}$|^(feature|fix|refactor|hotfix|release|conflict|chore)/.+$",
    "errorMsg": "Branch name structure: feature/short-description\nAllowed prefixes: feature, fix, refactor, hotfix, release, conflict, chore"
  },
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
