#!/usr/bin/env sh

set -e

# 1️⃣ Validate branch name
echo "🔖 Validating branch name..."
npx validate-branch-name || {
  echo "❌ Invalid branch name. Push aborted."
  exit 1
}

# 2️⃣ Repo size check — block large files over 1024KB
echo "📦 Checking for large tracked files..."
LIMIT_KB=1024
LARGE_FILES=$(git ls-files | xargs -I{} sh -c 'size=$(wc -c < "{}"); if [ "$size" -gt '"$((LIMIT_KB * 1024))"' ]; then echo "{} ($(( size / 1024 ))KB)"; fi' 2>/dev/null)
if [ -n "$LARGE_FILES" ]; then
  echo "❌ Large files detected (over ${LIMIT_KB}KB):"
  echo "$LARGE_FILES"
  echo "Remove or gitignore them before pushing."
  exit 1
fi
echo "✅ No large files found."

# 3️⃣ Run tests before push
echo "🧪 Running all tests before push..."
# pnpm test || {
#   echo "❌ Tests failed. Push aborted."
#   exit 1
# }

# 3️⃣ Protected branch checks for main
protected_branch='refs/heads/main'
current_user=$(git config user.email)
allowed_user='shownzy001@gmail.com'
z40=0000000000000000000000000000000000000000

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "$protected_branch" ]; then
    if [ "$current_user" != "$allowed_user" ]; then
      echo "❌ Only $allowed_user can push to main."
      exit 1
    fi

    if [ "$local_sha" = "$z40" ]; then
      echo "❌ Deleting main is restricted."
      exit 1
    fi

    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha"; then
      echo "❌ Force push to main is restricted."
      exit 1
    fi
  fi
done

echo "✅ Pre-push checks passed."

exit 0
